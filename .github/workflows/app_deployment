name: Manual App Redeploy

on:
  workflow_dispatch:   # manual trigger only

jobs:
  deploy:
    runs-on: ubuntu-22.04

    steps:
      - name: Checkout app repo
        uses: actions/checkout@v4

      - name: Checkout private data repo
        uses: actions/checkout@v4
        with:
          repository: tylerrchia/UCLA-Football-Strength-App-DATA
          token: ${{ secrets.DATA_REPO_PAT }}
          path: data-repo

      - name: Copy data and images into app/
        run: |
          mkdir -p app/data
          cp data-repo/data/*.rds app/data/

          # Copy images
          if [ -d "data-repo/HEADSHOTS" ]; then
            mkdir -p app/www/HEADSHOTS
            cp -r data-repo/HEADSHOTS/. app/www/HEADSHOTS/
          fi
          if [ -d "data-repo/prepics" ]; then
            mkdir -p app/www/prepics
            cp -r data-repo/prepics/. app/www/prepics/
          fi
          if [ -d "data-repo/postpics" ]; then
            mkdir -p app/www/postpics
            cp -r data-repo/postpics/. app/www/postpics/
          fi

      - name: Setup R
        uses: r-lib/actions/setup-r@v2
        with:
          r-version: '4.5.2'

      - name: Restore renv
        uses: r-lib/actions/setup-renv@v2

      - name: Install rsconnect
        run: R -e 'install.packages("rsconnect")'

      - name: Deploy to shinyapps.io
        env:
          SHINYAPPS_ACCOUNT: ${{ secrets.SHINYAPPS_ACCOUNT }}
          SHINYAPPS_TOKEN:   ${{ secrets.SHINYAPPS_TOKEN }}
          SHINYAPPS_SECRET:  ${{ secrets.SHINYAPPS_SECRET }}
          SHINYAPPS_APPNAME: ${{ secrets.SHINYAPPS_APPNAME }}
        run: |
          R -e '
            rsconnect::setAccountInfo(
              name   = Sys.getenv("SHINYAPPS_ACCOUNT"),
              token  = Sys.getenv("SHINYAPPS_TOKEN"),
              secret = Sys.getenv("SHINYAPPS_SECRET")
            )
            rsconnect::deployApp(
              appDir        = "app",
              appPrimaryDoc = "app_automated.r",
              appName       = Sys.getenv("SHINYAPPS_APPNAME"),
              forceUpdate   = TRUE,
              launch.browser = FALSE
            )
          '
